# Copy this file to .env and fill in real values. The app asserts both
# variables at startup and will hard-fail if either is missing.

ANTHROPIC_API_KEY="sk-ant-..."

# Default to Haiku for dev work. Haiku 4.5 is roughly 12x cheaper than Sonnet
# for this POC workload (light tool routing + 2-sentence sampling summaries)
# while preserving about 90% tool-routing accuracy. Switch to claude-sonnet-5
# or claude-opus-4-8 for live demos where tool-selection determinism matters
# more than per-token cost.
CLAUDE_MODEL="claude-haiku-4-5-20251001"
