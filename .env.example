# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Model Configuration (optional - defaults shown)
CLAUDE_MODEL=claude-sonnet-5
# Options: claude-opus-4-8 (1M ctx, $5/$25), claude-sonnet-5 (1M ctx, $3/$15), claude-haiku-4-5-20251001 (1M ctx, $1/$5)
# verify current pricing at anthropic.com/pricing

# GitHub Integration (for Segment 3 & 4)
GITHUB_TOKEN=ghp_your-github-token
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo

# Slack Integration (optional - for Segment 3)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C01234567

# MCP Server Configuration
MCP_MEMORY_PATH=./data/memory.json

# Development Settings
LOG_LEVEL=info
DEBUG=false
