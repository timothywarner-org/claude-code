{
  "mcpServers": {
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "DocumentMCP-ClaudeCode": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PROJECT_DIR:-.}/mcp-example/mcp_cli",
        "${CLAUDE_PROJECT_DIR:-.}/mcp-example/mcp_cli/mcp_server.py"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    }
  }
}
