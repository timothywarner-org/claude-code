{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-shared Claude Code settings. Committed to git so learners cloning this repo get the canonical Segment 4 MCP demo target. Personal overrides go in settings.local.json (gitignored).",
  "mcpServers": {
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "DocumentMCP-ClaudeCode": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "C:/github/claude-code/mcp-teaching-kit-main",
        "C:/github/claude-code/mcp-teaching-kit-main/mcp_server.py"
      ]
    }
  }
}
